    "question-line": {
      "regex": "^(\\h*\\?)(.*)$",
      "matchPosition": 1,
      "color": "#FF8F00",
      "font": "AvenirNext-DemiBold"
    },
    "question-text": {
      "regex": "^(\\h*\\?)(.*)$",
      "matchPosition": 2,
      "color": "#FFA726",
      "font": "AvenirNext-Regular"
    },
    "important-line": {
      "regex": "^(\\h*!)(.*)$",
      "matchPosition": 1,
      "color": "#E91E3A",
      "font": "AvenirNext-DemiBold"
    },
