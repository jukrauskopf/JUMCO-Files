      "regex": "^\\h*//",
      "matchPosition": 0,
      "color": "#8E24AA",
      "font": "AvenirNext-DemiBold"
    },
    "discussed-text": {
      "regex": "^\\h*//(.*)$",
      "matchPosition": 1,
      "color": "#BA68C8",
      "font": "AvenirNext-Regular"
